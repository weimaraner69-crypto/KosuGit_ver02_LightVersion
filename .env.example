# 開発用環境変数テンプレート（値は例。機密情報は設定しない）

# --- CSP違反通知（SEC-010） ---
# 未設定時は通知無効
CSP_SPIKE_ALERT_WEBHOOK_URL=

# 任意。実運用ではローカル .env またはシークレットストアのみで管理
CSP_SPIKE_ALERT_BEARER_TOKEN=

# 通知タイムアウト秒（default: 3.0）
CSP_SPIKE_ALERT_TIMEOUT_SECONDS=3.0

# 再送回数（default: 2）
CSP_SPIKE_ALERT_MAX_RETRIES=2

# 指数バックオフ初期待機秒（default: 0.5）
CSP_SPIKE_ALERT_RETRY_BACKOFF_SECONDS=0.5

# 同一directiveの通知クールダウン分（default: 30）
CSP_SPIKE_ALERT_COOLDOWN_MINUTES=60

# 高増加率でクールダウン解除する閾値（default: 5.0）
CSP_SPIKE_ALERT_PRIORITY_INCREASE_RATIO_THRESHOLD=8.0

# directive別の優先通知閾値上書き（形式: directive=ratio,directive=ratio）
# 値未指定（例: script-src-elem=）は設定エラー
CSP_SPIKE_ALERT_PRIORITY_INCREASE_RATIO_THRESHOLD_OVERRIDES=script-src-elem=3.0,style-src=4.0,img-src=6.0
